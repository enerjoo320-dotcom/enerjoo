{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Solar energy system components (panels, inverters, batteries) from suppliers.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "English name of the product" },
        "nameAr": { "type": "string", "description": "Arabic name of the product" },
        "type": { "type": "string", "description": "Type of product (panel, inverter, battery)" },
        "supplierId": { "type": "string", "description": "Reference to the supplier user document" },
        "price": { "type": "number", "description": "Price in Egyptian Pounds" },
        "specifications": { "type": "object", "description": "Product-specific tech specs" },
        "updatedAt": { "type": "object", "format": "timestamp", "description": "Server timestamp of last update" }
      },
      "required": ["name", "nameAr", "type", "price", "supplierId"]
    },
    "User": {
      "title": "User",
      "description": "User profiles representing customers, suppliers, and admins.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "English full name" },
        "nameAr": { "type": "string", "description": "Arabic full name" },
        "type": { "type": "string", "enum": ["customer", "supplier", "admin"], "description": "User role" },
        "verified": { "type": "boolean", "description": "Whether the supplier is verified by admin" },
        "phone": { "type": "string", "description": "Contact or WhatsApp phone number" },
        "email": { "type": "string", "description": "User email address" },
        "location": { "type": "string", "description": "Supplier state or location" },
        "rating": { "type": "number", "description": "Supplier average rating" },
        "totalSales": { "type": "number", "description": "Total sales count of supplier" },
        "avatar": { "type": "string", "description": "User avatar icon URL" }
      },
      "required": ["name", "type"]
    },
    "Quotation": {
      "title": "Quotation",
      "description": "Quotation requests generated by the AI Solar Calculator for potential leads",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the requester" },
        "phone": { "type": "string", "description": "Phone number or WhatsApp" },
        "notes": { "type": "string", "description": "Extra optional notes from requester" },
        "systemType": { "type": "string", "description": "Solar system type: on-grid, off-grid, hybrid, pump" },
        "targetTier": { "type": "string", "description": "Tier: budget, recommended, premium" },
        "priceEstimate": { "type": "number", "description": "Calculated total price estimate" },
        "systemSpecs": { "type": "string", "description": "Serialized specifications of system" },
        "location": { "type": "string", "description": "Governorate/City selection" },
        "createdAt": { "type": "object", "format": "timestamp", "description": "Server creation timestamp" },
        "status": { "type": "string", "enum": ["pending", "processed", "contacted"], "description": "Status of the lead" }
      },
      "required": ["name", "phone", "systemType", "targetTier", "priceEstimate"]
    },
    "Review": {
      "title": "Review",
      "description": "Star ratings and written feedback left by authenticated customers on solar products.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the authenticated user who left the review" },
        "userName": { "type": "string", "description": "The name of the user who left the review" },
        "rating": { "type": "number", "description": "Star rating out of 5 (integer 1-5)" },
        "comment": { "type": "string", "description": "Optional written feedback or comment text" },
        "createdAt": { "type": "object", "format": "timestamp", "description": "Server timestamp of review creation" }
      },
      "required": ["userId", "userName", "rating", "createdAt"]
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": "Product",
      "description": "Collection of solar products in the Egyptian catalog."
    },
    "users/{userId}": {
      "schema": "User",
      "description": "User and supplier profile documents."
    },
    "quotations/{quotationId}": {
      "schema": "Quotation",
      "description": "Calculated quote inquiries submitted by leads."
    },
    "products/{productId}/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Subcollection of star ratings and written reviews for a product."
    }
  }
}
