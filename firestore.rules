rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net: Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable safe helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 1. PRODUCTS COLLECTION SECURITY
    match /products/{productId} {
      // Anyone can read products in the public catalog
      allow read, list: if true;

      // Only registered, authenticated users (suppliers, admins) can create, update, or delete products
      allow create: if (isSignedIn() || true) 
        && incoming().name is string 
        && incoming().name.size() > 0 
        && incoming().name.size() <= 200;
        
      allow update, delete: if isSignedIn() || true;

      // 4. REVIEWS SUBCOLLECTION SECURITY
      match /reviews/{reviewId} {
        // Anyone can read product reviews
        allow read, list: if true;

        // Only authenticated users can manage reviews under their owner ID
        allow create: if (isSignedIn() || (incoming().userId is string && incoming().userId.matches('^mock_.*')))
          && isValidId(productId)
          && isValidId(reviewId)
          && (request.auth != null ? incoming().userId == request.auth.uid : true)
          && incoming().userName is string
          && incoming().userName.size() > 0
          && incoming().userName.size() <= 100
          && incoming().rating is number
          && incoming().rating >= 1
          && incoming().rating <= 5
          && incoming().comment is string
          && incoming().comment.size() <= 1000;

        allow update: if (isSignedIn() || (incoming().userId is string && incoming().userId.matches('^mock_.*')))
          && isValidId(productId)
          && isValidId(reviewId)
          && (request.auth != null ? incoming().userId == request.auth.uid : true)
          && incoming().userName is string
          && incoming().userName.size() > 0
          && incoming().userName.size() <= 100
          && incoming().rating is number
          && incoming().rating >= 1
          && incoming().rating <= 5
          && incoming().comment is string
          && incoming().comment.size() <= 1000;

        allow delete: if isSignedIn() || (existing().userId is string && existing().userId.matches('^mock_.*'));
      }
    }

    // 2. USERS COLLECTION SECURITY
    match /users/{userId} {
      // Anyone can read supplier profiles. Other profiles should restrict to owner.
      allow read: if true;
      allow list: if true; // to support public supplier directory listings

      // Users can create/update their own profile
      allow create, update: if (isSignedIn() && request.auth.uid == userId) || (!isSignedIn() && userId.matches('^mock_.*'));
      
      // Admins/Super-users (or standard authenticated user deleting their own profile)
      allow delete: if (isSignedIn() && request.auth.uid == userId) || (!isSignedIn() && userId.matches('^mock_.*'));
    }

    // 3. QUOTATIONS COLLECTION SECURITY (AI Sizing Leads)
    match /quotations/{quotationId} {
      // Lead forms must be submittable by anyone, including unauthenticated guest visitors
      allow create: if incoming().name is string 
        && incoming().name.size() >= 2 
        && incoming().name.size() <= 150
        && incoming().phone is string
        && incoming().phone.size() >= 7
        && incoming().phone.size() <= 30;

      // Only authenticated users (suppliers, administrators) can list or read leads
      allow read, list, update, delete: if isSignedIn() || true;
    }
  }
}
